{
  "expo": {
    "name": "Sober Streak",
    "slug": "sober-streak",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "soberstreak",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.thecodersamet.soberstreak",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.thecodersamet.soberstreak",
      "adaptiveIcon": {
        "backgroundColor": "#FAEEDA",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#BA7517"
        }
      ],
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "12f81abd-777b-487d-8665-d04ec6917bb7"
      }
    }
  }
}
